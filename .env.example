APP_NAME=Resume Intelligence Platform
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./resume_intelligence.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=resume_candidates
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DATA_ROOT=./data
RESUME_ROOT=./data/resumes
EXPORT_ROOT=./data/exports
DEFAULT_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RANKING_REQUIRED_SKILL_WEIGHT=0.35
RANKING_PREFERRED_SKILL_WEIGHT=0.15
RANKING_SEMANTIC_WEIGHT=0.25
RANKING_EXPERIENCE_WEIGHT=0.1
RANKING_DOMAIN_WEIGHT=0.1
RANKING_EDUCATION_WEIGHT=0.05
ENABLE_OPENAI_EXTRACTION=true
ENABLE_QDRANT=true
